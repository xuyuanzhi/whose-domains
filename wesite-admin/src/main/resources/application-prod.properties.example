# Copy this file to application-prod.properties and fill in your values.
# Values referenced via ${ENV_VAR} can also be supplied as environment variables.

#server
server.port = 8082
server.servlet.context-path = /

#database
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.datasource.url=${WD_DB_URL:jdbc:mysql://localhost:3306/wesitedb?allowMultiQueries=true&useUnicode=true&characterEncoding=UTF-8&useSSL=false&autoreconnect=true}
spring.datasource.username=${WD_DB_USERNAME:your-db-username}
spring.datasource.password=${WD_DB_PASSWORD:your-db-password}

#maxmind GeoIP2 database paths — download from https://www.maxmind.com/
maxmind.city.file.path = /path/to/GeoLite2-City.mmdb
maxmind.asn.file.path = /path/to/GeoLite2-ASN.mmdb

#sitemap output directory (must be writable)
sitemap.root = /var/www/sitemap/

#redis
spring.redis.host = 127.0.0.1
spring.redis.port = 6379
spring.redis.password = ${REDIS_PASSWORD:}
spring.redis.pool.max-active = 200
spring.redis.pool.max-wait = -1
